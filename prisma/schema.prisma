generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Media {
  id        String   @id @default(cuid())
  filename  String
  path      String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())

  displayItems DisplayItem[]
  tags         MediaTag[]
}

model Tag {
  id    String     @id @default(cuid())
  name  String     @unique
  media MediaTag[]
}

model MediaTag {
  id      String @id @default(cuid())
  mediaId String
  media   Media  @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  tagId   String
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([mediaId, tagId])
}

model Display {
  id           String   @id @default(cuid())
  name         String
  mode         String   @default("single")
  interval     Int      @default(5)
  scheduleMode String   @default("none")
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  items DisplayItem[]
}

model DisplayItem {
  id           String  @id @default(cuid())
  order        Int     @default(0)
  showUntil    String?
  scheduleDate String?

  displayId String
  display   Display @relation(fields: [displayId], references: [id], onDelete: Cascade)

  mediaId String
  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
}
